# ── Backend (backend/.env) ────────────────────────────────

# Real-time speech-to-text — https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# LLM (Groq / llama-3.1-8b-instant) — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: backend port (default 3001)
PORT=3001
